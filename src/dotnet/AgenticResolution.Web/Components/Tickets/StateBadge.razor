<span class="badge badge-pill state-badge @CssClass">@StateLabel</span>

@code {
    [Parameter]
    public TicketState State { get; set; }

    private string CssClass => State switch
    {
        TicketState.New => "state-new",
        TicketState.InProgress => "state-inprogress",
        TicketState.OnHold => "state-onhold",
        TicketState.Resolved => "state-resolved",
        TicketState.Closed => "state-closed",
        TicketState.Cancelled => "state-cancelled",
        TicketState.Escalated => "state-escalated",
        _ => "state-closed"
    };

    private string StateLabel => State switch
    {
        TicketState.InProgress => "In Progress",
        TicketState.New => "New",
        TicketState.OnHold => "On Hold",
        TicketState.Resolved => "Resolved",
        TicketState.Closed => "Closed",
        TicketState.Cancelled => "Cancelled",
        TicketState.Escalated => "Escalated",
        _ => State.ToString()
    };
}
