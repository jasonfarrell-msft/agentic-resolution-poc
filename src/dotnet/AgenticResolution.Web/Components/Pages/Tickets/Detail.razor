@page "/tickets/{Number}"
@implements IDisposable
@inject TicketApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Ticket @Number — TicketNow</PageTitle>

@if (!ApiClient.IsConfigured)
{
    <div class="alert-api-unconfigured">
        <div class="alert-icon">⚙️</div>
        <div>
            <strong>API not configured</strong>
            <p>The backend API is not reachable. Set <code>ApiClient:BaseUrl</code> in the app configuration to connect.</p>
        </div>
    </div>
}
else if (IsLoading)
{
    <div class="loading-skeleton"></div>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">
        <strong>Could not load ticket.</strong> @ErrorMessage
        <div class="mt-2">
            <button class="btn btn-outline-danger btn-sm" @onclick="RetryLoad">Retry</button>
            <a class="btn btn-outline-secondary btn-sm ms-2" href="/tickets">Back to Tickets</a>
        </div>
    </div>
}
else if (Details is null)
{
    <div class="empty-state">
        <h4>Ticket not found.</h4>
        <p>Return to the ticket list to continue.</p>
        <a class="btn btn-outline-secondary" href="/tickets" aria-label="Back to ticket list">Back to ticket list</a>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h1>Ticket @Details.Ticket.Number</h1>
            <p class="text-muted">@Details.Ticket.ShortDescription</p>
            <div class="ticket-header-summary" aria-label="Ticket status summary">
                <div class="summary-pill">
                    <span class="summary-label">Status</span>
                    <span class="summary-value">
                        @if (IsEscalated(Details.Ticket))
                        {
                            <span class="badge badge-pill run-status run-escalated">Escalated</span>
                        }
                        else
                        {
                            <StateBadge State="Details.Ticket.State" />
                        }
                        @if (!IsEscalated(Details.Ticket) && HasDistinctStatus(Details.Ticket))
                        {
                            <span class="summary-secondary">@Details.Ticket.Status</span>
                        }
                    </span>
                </div>
                <div class="summary-pill">
                    <span class="summary-label">Assigned To</span>
                    <span class="summary-value">@GetAssignee(Details.Ticket)</span>
                </div>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2 justify-content-end">
            <a class="btn btn-outline-secondary" href="/tickets" aria-label="Back to ticket list">← Back to ticket list</a>
            @if (CanResolve)
            {
                <a class="btn btn-primary" href="@ResolveUrl">
                    Resolve with AI
                </a>
            }
        </div>
    </div>

    <div class="detail-grid mb-4">
        <div class="detail-card">
            <h4>Summary</h4>
            <div class="detail-field">
                <span class="label">Priority</span>
                <PriorityBadge Priority="Details.Ticket.Priority" />
            </div>
            <div class="detail-field">
                <span class="label">Caller</span>
                <span>@(string.IsNullOrWhiteSpace(Details.Ticket.Caller) ? "Unknown" : Details.Ticket.Caller)</span>
            </div>
            <div class="detail-field">
                <span class="label">Category</span>
                <span>@(string.IsNullOrWhiteSpace(Details.Ticket.Category) ? "Uncategorized" : Details.Ticket.Category)</span>
            </div>
            <div class="detail-field">
                <span class="label">Created</span>
                <span>@Details.Ticket.CreatedAt.ToLocalTime().ToString("f")</span>
            </div>
            @if (Details.Ticket.UpdatedAt is not null)
            {
                <div class="detail-field">
                    <span class="label">Last Updated</span>
                    <span>@Details.Ticket.UpdatedAt.Value.ToLocalTime().ToString("f")</span>
                </div>
            }
        </div>

        <div class="detail-card">
            <h4>Description</h4>
            <p>@(string.IsNullOrWhiteSpace(Details.Ticket.Description) ? "No additional description provided." : Details.Ticket.Description)</p>
        </div>
    </div>

    <div class="detail-card mb-4">
        <h4>Comments</h4>
        @if (OrderedComments.Count == 0)
        {
            <div class="empty-state">No comments yet.</div>
        }
        else
        {
            <div class="comment-list">
                @foreach (var comment in OrderedComments)
                {
                    <div class="comment-card @(comment.IsInternal ? "internal" : string.Empty)">
                        <div class="comment-meta">
                            <span>@comment.Author</span>
                            <span>@comment.CreatedAt.ToLocalTime().ToString("g")</span>
                        </div>
                        <div class="mt-2">@comment.Body</div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="mt-4">
        <a class="btn btn-outline-secondary" href="/tickets" aria-label="Back to ticket list">← Back to ticket list</a>
    </div>
}

@code {
    [Parameter]
    public string Number { get; set; } = string.Empty;

    private TicketDetailResponse? Details;
    private bool IsLoading = true;
    private string? ErrorMessage;
    private CancellationTokenSource? _loadCts;

    protected override async Task OnParametersSetAsync()
    {
        await StartLoadingDetailsAsync();
    }

    private async Task StartLoadingDetailsAsync()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();

        IsLoading = true;
        Details = null;
        ErrorMessage = null;

        await LoadDetailsAsync(Number, _loadCts.Token);
    }

    private async Task LoadDetailsAsync(string number, CancellationToken cancellationToken)
    {
        if (!ApiClient.IsConfigured)
        {
            IsLoading = false;
            return;
        }

        try
        {
            Details = await ApiClient.GetTicketDetailsAsync(number, cancellationToken);
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            if (!cancellationToken.IsCancellationRequested)
            {
                IsLoading = false;
            }
        }
    }

    private IReadOnlyList<CommentResponse> OrderedComments =>
        Details is null
            ? Array.Empty<CommentResponse>()
            : Details.Comments.OrderBy(comment => comment.CreatedAt).ToList();

    private bool CanResolve =>
        Details?.Ticket.State is TicketState.New or TicketState.InProgress;

    private string ResolveUrl => $"/tickets/{Uri.EscapeDataString(Number)}/resolve";

    private async Task RetryLoad()
    {
        await StartLoadingDetailsAsync();
    }

    private static string GetAssignee(TicketResponse ticket) =>
        !string.IsNullOrWhiteSpace(ticket.Assignee)
            ? ticket.Assignee
            : string.IsNullOrWhiteSpace(ticket.AssignedTo) ? "Unassigned" : ticket.AssignedTo;

    private static bool HasDistinctStatus(TicketResponse ticket)
    {
        if (string.IsNullOrWhiteSpace(ticket.Status))
        {
            return false;
        }

        var state = ticket.State.ToString().Replace("InProgress", "In Progress", StringComparison.Ordinal);
        return !ticket.Status.Equals(state, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsEscalated(TicketResponse ticket) =>
        ticket.AgentAction?.Equals("escalated_to_human", StringComparison.OrdinalIgnoreCase) == true ||
        ticket.Status?.Equals("Escalated", StringComparison.OrdinalIgnoreCase) == true;

    public void Dispose()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
    }
}
