@page "/tickets/{Number}"
@implements IDisposable
@inject TicketApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Ticket @Number — TicketNow</PageTitle>

@if (!ApiClient.IsConfigured)
{
    <div class="alert-api-unconfigured">
        <div class="alert-icon">⚙️</div>
        <div>
            <strong>API not configured</strong>
            <p>The backend API is not reachable. Set <code>ApiClient:BaseUrl</code> in the app configuration to connect.</p>
        </div>
    </div>
}
else if (IsLoading)
{
    <div class="loading-skeleton"></div>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">
        <strong>Could not load ticket.</strong> @ErrorMessage
        <div class="mt-2">
            <button class="btn btn-outline-danger btn-sm" @onclick="RetryLoad">Retry</button>
            <a class="btn btn-outline-secondary btn-sm ms-2" href="/tickets">Back to Tickets</a>
        </div>
    </div>
}
else if (Details is null)
{
    <div class="empty-state">
        <h4>Ticket not found.</h4>
        <p>Return to the ticket list to continue.</p>
        <a class="btn btn-outline-secondary" href="/tickets" aria-label="Back to ticket list">Back to ticket list</a>
    </div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(AbandonErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Failed to abandon workflow.</strong> @AbandonErrorMessage
            <button type="button" class="btn-close" @onclick="@(() => AbandonErrorMessage = null)" aria-label="Close"></button>
        </div>
    }
    @if (AbandonSucceeded)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Workflow abandoned.</strong> The ticket workflow has been stopped.
            <button type="button" class="btn-close" @onclick="@(() => AbandonSucceeded = false)" aria-label="Close"></button>
        </div>
    }
    <div class="page-header">
        <div>
            <h1>Ticket @Details.Ticket.Number</h1>
            <p class="text-muted">@Details.Ticket.ShortDescription</p>
            <div class="ticket-header-summary" aria-label="Ticket status summary">
                <div class="summary-pill">
                    <span class="summary-label">Status</span>
                    <span class="summary-value">
                        @if (IsEscalated(Details.Ticket))
                        {
                            <span class="badge badge-pill run-status run-escalated">Escalated</span>
                        }
                        else
                        {
                            <StateBadge State="Details.Ticket.State" />
                        }
                        @if (!IsEscalated(Details.Ticket) && HasDistinctStatus(Details.Ticket))
                        {
                            <span class="summary-secondary">@Details.Ticket.Status</span>
                        }
                    </span>
                </div>
                <div class="summary-pill">
                    <span class="summary-label">Assigned To</span>
                    <span class="summary-value">@GetAssignee(Details.Ticket)</span>
                </div>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2 justify-content-end">
            <a class="btn btn-outline-secondary" href="/tickets" aria-label="Back to ticket list">← Back to ticket list</a>
            @if (CanAbandon)
            {
                <button class="btn btn-outline-danger" @onclick="AbandonWorkflowAsync" disabled="@IsAbandoning">
                    @if (IsAbandoning)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Abandoning...</span>
                    }
                    else
                    {
                        <span>Abandon Workflow</span>
                    }
                </button>
            }
            @if (CanResolve)
            {
                <a class="btn btn-primary" href="@ResolveUrl">
                    Resolve with AI
                </a>
            }
        </div>
    </div>

    <div class="detail-grid mb-4">
        <div class="detail-card">
            <h4>Summary</h4>
            <div class="detail-field">
                <span class="label">Priority</span>
                <PriorityBadge Priority="Details.Ticket.Priority" />
            </div>
            <div class="detail-field">
                <span class="label">Caller</span>
                <span>@(string.IsNullOrWhiteSpace(Details.Ticket.Caller) ? "Unknown" : Details.Ticket.Caller)</span>
            </div>
            <div class="detail-field">
                <span class="label">Category</span>
                <span>@(string.IsNullOrWhiteSpace(Details.Ticket.Category) ? "Uncategorized" : Details.Ticket.Category)</span>
            </div>
            <div class="detail-field">
                <span class="label">Created</span>
                <span>@Details.Ticket.CreatedAt.ToLocalTime().ToString("f")</span>
            </div>
            @if (Details.Ticket.UpdatedAt is not null)
            {
                <div class="detail-field">
                    <span class="label">Last Updated</span>
                    <span>@Details.Ticket.UpdatedAt.Value.ToLocalTime().ToString("f")</span>
                </div>
            }
        </div>

        <div class="detail-card">
            <h4>Change Status</h4>
            @if (!string.IsNullOrWhiteSpace(StatusChangeError))
            {
                <div class="alert alert-danger alert-dismissible fade show mb-2" role="alert">
                    @StatusChangeError
                    <button type="button" class="btn-close" @onclick="@(() => StatusChangeError = null)" aria-label="Close"></button>
                </div>
            }
            @if (StatusChangeSucceeded)
            {
                <div class="alert alert-success alert-dismissible fade show mb-2" role="alert">
                    Status updated successfully.
                    <button type="button" class="btn-close" @onclick="@(() => StatusChangeSucceeded = false)" aria-label="Close"></button>
                </div>
            }
            <div class="d-flex flex-wrap gap-2 align-items-center" @key="Details?.Ticket.State">
                <select class="form-select form-select-sm w-auto" @bind="SelectedState">
                    @foreach (var state in AvailableStates)
                    {
                        <option value="@state">@FormatState(state)</option>
                    }
                </select>
                <button class="btn btn-sm btn-outline-primary" @onclick="ChangeStatusAsync" disabled="@(IsChangingStatus || SelectedState == Details.Ticket.State)">
                    @if (IsChangingStatus)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Apply
                </button>
            </div>
        </div>

        <div class="detail-card">
            <h4>Description</h4>
            <p>@(string.IsNullOrWhiteSpace(Details.Ticket.Description) ? "No additional description provided." : Details.Ticket.Description)</p>
        </div>
    </div>

    @if (HasAiResults(Details.Ticket))
    {
        <div class="detail-card mb-4">
            <h4>AI Resolution</h4>
            @if (!string.IsNullOrWhiteSpace(Details.Ticket.AgentAction))
            {
                <div class="detail-field">
                    <span class="label">Action Taken</span>
                    <span>@FormatAgentAction(Details.Ticket.AgentAction)</span>
                </div>
            }
            @if (Details.Ticket.AgentConfidence.HasValue)
            {
                <div class="detail-field">
                    <span class="label">Confidence</span>
                    <span>@($"{Details.Ticket.AgentConfidence.Value:P0}")</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Details.Ticket.MatchedTicketNumber))
            {
                <div class="detail-field">
                    <span class="label">KB / Source</span>
                    <span>@Details.Ticket.MatchedTicketNumber</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Details.Ticket.ResolutionNotes))
            {
                <div class="detail-field flex-column">
                    <span class="label">Resolution Notes</span>
                    <p class="mt-1 mb-0">@Details.Ticket.ResolutionNotes</p>
                </div>
            }
        </div>
    }

    <div class="detail-card mb-4">
        <h4>Comments</h4>
        @if (OrderedComments.Count == 0)
        {
            <div class="empty-state">No comments yet.</div>
        }
        else
        {
            <div class="comment-list">
                @foreach (var comment in OrderedComments)
                {
                    <div class="comment-card @(comment.IsInternal ? "internal" : string.Empty)">
                        <div class="comment-meta">
                            <span>@comment.Author</span>
                            <span>@comment.CreatedAt.ToLocalTime().ToString("g")</span>
                        </div>
                        <div class="mt-2">@comment.Body</div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="mt-4">
        <a class="btn btn-outline-secondary" href="/tickets" aria-label="Back to ticket list">← Back to ticket list</a>
    </div>
}

@code {
    [Parameter]
    public string Number { get; set; } = string.Empty;

    private TicketDetailResponse? Details;
    private bool IsLoading = true;
    private string? ErrorMessage;
    private string? AbandonErrorMessage;
    private bool AbandonSucceeded;
    private bool IsAbandoning;
    private string? StatusChangeError;
    private bool StatusChangeSucceeded;
    private bool IsChangingStatus;
    private TicketState SelectedState;
    private CancellationTokenSource? _loadCts;

    protected override async Task OnParametersSetAsync()
    {
        await StartLoadingDetailsAsync();
    }

    private async Task StartLoadingDetailsAsync()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();

        IsLoading = true;
        Details = null;
        ErrorMessage = null;
        SelectedState = default;

        await LoadDetailsAsync(Number, _loadCts.Token);
    }

    private async Task LoadDetailsAsync(string number, CancellationToken cancellationToken)
    {
        if (!ApiClient.IsConfigured)
        {
            IsLoading = false;
            return;
        }

        try
        {
            Details = await ApiClient.GetTicketDetailsAsync(number, cancellationToken);
            if (Details is not null)
            {
                SelectedState = Details.Ticket.State;
            }
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            if (!cancellationToken.IsCancellationRequested)
            {
                IsLoading = false;
            }
        }
    }

    private IReadOnlyList<CommentResponse> OrderedComments =>
        Details is null
            ? Array.Empty<CommentResponse>()
            : Details.Comments.OrderBy(comment => comment.CreatedAt).ToList();

    private bool CanResolve =>
        Details?.Ticket.State is TicketState.New or TicketState.InProgress;

    private bool CanAbandon =>
        Details?.Ticket.State is TicketState.InProgress;

    private string ResolveUrl => $"/tickets/{Uri.EscapeDataString(Number)}/resolve";

    private async Task RetryLoad()
    {
        await StartLoadingDetailsAsync();
    }

    private async Task AbandonWorkflowAsync()
    {
        if (IsAbandoning || string.IsNullOrWhiteSpace(Number))
        {
            return;
        }

        AbandonErrorMessage = null;
        AbandonSucceeded = false;
        IsAbandoning = true;

        try
        {
            await ApiClient.AbandonWorkflowAsync(Number);
            AbandonSucceeded = true;
            await StartLoadingDetailsAsync();
        }
        catch (Exception ex)
        {
            AbandonErrorMessage = ex.Message;
        }
        finally
        {
            IsAbandoning = false;
        }
    }

    private static string GetAssignee(TicketResponse ticket) =>
        !string.IsNullOrWhiteSpace(ticket.Assignee)
            ? ticket.Assignee
            : string.IsNullOrWhiteSpace(ticket.AssignedTo) ? "Unassigned" : ticket.AssignedTo;

    private static bool HasDistinctStatus(TicketResponse ticket)
    {
        if (string.IsNullOrWhiteSpace(ticket.Status))
        {
            return false;
        }

        var state = ticket.State.ToString().Replace("InProgress", "In Progress", StringComparison.Ordinal);
        return !ticket.Status.Equals(state, StringComparison.OrdinalIgnoreCase);
    }

    private static bool HasAiResults(TicketResponse ticket) =>
        !string.IsNullOrWhiteSpace(ticket.AgentAction) ||
        ticket.AgentConfidence.HasValue ||
        !string.IsNullOrWhiteSpace(ticket.MatchedTicketNumber) ||
        !string.IsNullOrWhiteSpace(ticket.ResolutionNotes);

    private static string FormatAgentAction(string action) => action switch
    {
        "auto_resolved" => "Auto Resolved",
        "resolved" => "Resolved",
        "escalated_to_human" => "Escalated to Human",
        _ => System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(action.Replace("_", " "))
    };

    private static bool IsEscalated(TicketResponse ticket) =>
        ticket.AgentAction?.Equals("escalated_to_human", StringComparison.OrdinalIgnoreCase) == true ||
        ticket.Status?.Equals("Escalated", StringComparison.OrdinalIgnoreCase) == true;

    private async Task ChangeStatusAsync()
    {
        if (IsChangingStatus || Details is null) return;

        StatusChangeError = null;
        StatusChangeSucceeded = false;
        IsChangingStatus = true;

        try
        {
            await ApiClient.UpdateTicketStatusAsync(Details.Ticket.Id, SelectedState);
            StatusChangeSucceeded = true;
            await StartLoadingDetailsAsync();
        }
        catch (Exception ex)
        {
            StatusChangeError = ex.Message;
        }
        finally
        {
            IsChangingStatus = false;
        }
    }

    private static IEnumerable<TicketState> AvailableStates =>
        Enum.GetValues<TicketState>();

    private static string FormatState(TicketState state) => state switch
    {
        TicketState.InProgress => "In Progress",
        _ => state.ToString()
    };

    public void Dispose()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
    }
}
