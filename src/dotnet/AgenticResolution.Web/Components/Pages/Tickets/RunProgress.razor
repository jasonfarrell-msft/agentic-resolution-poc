@page "/tickets/{Number}/resolve"
@using System.Text.Json
@implements IDisposable
@inject ResolutionApiClient ResolutionApi
@inject NavigationManager Navigation

<PageTitle>Resolving @Number — TicketNow</PageTitle>

@if (!ResolutionApi.IsConfigured)
{
    <div class="alert-api-unconfigured">
        <div class="alert-icon">⚙️</div>
        <div>
            <strong>Resolution API not configured</strong>
            <p>Set <code>ResolutionApi:BaseUrl</code> in the app configuration to connect to the Python Resolution API.</p>
        </div>
    </div>
}
else
{
    <div class="run-progress-header">
        <div>
            <h1>Resolving Ticket @Number</h1>
            <p class="text-muted">AI-powered resolution in progress</p>
        </div>
        @if (IsComplete)
        {
            <span class="badge bg-success">Complete</span>
        }
        else if (HasError)
        {
            <span class="badge bg-danger">Error</span>
        }
        else
        {
            <span class="badge bg-primary">Running</span>
        }
    </div>

    <div class="timeline">
        @foreach (var stage in Stages)
        {
            <div class="timeline-step">
                <div class="step-indicator @GetIndicatorClass(stage.Value)"></div>
                <div>
                    <div class="step-title">@FormatStageName(stage.Key)</div>
                    <div class="step-meta">
                        <span>@stage.Value.Status</span>
                        @if (stage.Value.Timestamp is not null)
                        {
                            <span>@stage.Value.Timestamp</span>
                        }
                    </div>
                    @if (stage.Value.ResultSummary is not null)
                    {
                        <div class="step-payload">@stage.Value.ResultSummary</div>
                    }
                </div>
            </div>
        }
    </div>

    @if (HasError)
    {
        <div class="alert alert-danger mt-3">
            <strong>Resolution failed:</strong> @ErrorMessage
            <div class="mt-2">
                <button class="btn btn-outline-danger btn-sm" @onclick="RetryAsync">Retry</button>
                <a class="btn btn-outline-secondary btn-sm ms-2" href="@($"/tickets/{Number}")">Back to Ticket</a>
            </div>
        </div>
    }
    else if (IsComplete)
    {
        <div class="final-card mt-3">
            <h4>Resolution Complete</h4>
            <p>Redirecting to ticket detail…</p>
        </div>
    }
    else if (!IsStarted)
    {
        <div class="loading-skeleton"></div>
    }
}

@code {
    [Parameter]
    public string Number { get; set; } = string.Empty;

    private Dictionary<string, StageState> Stages { get; } = new();
    private bool IsStarted;
    private bool IsComplete;
    private bool HasError;
    private string? ErrorMessage;
    private CancellationTokenSource? _cts;

    protected override async Task OnParametersSetAsync()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        Stages.Clear();
        IsComplete = false;
        HasError = false;
        ErrorMessage = null;
        IsStarted = false;

        await StreamResolutionAsync(_cts.Token);
    }

    private async Task StreamResolutionAsync(CancellationToken cancellationToken)
    {
        if (!ResolutionApi.IsConfigured)
        {
            return;
        }

        IsStarted = true;

        try
        {
            await foreach (var evt in ResolutionApi.StreamResolutionAsync(Number, cancellationToken))
            {
                UpdateStage(evt);
                await InvokeAsync(StateHasChanged);
            }

            // Stream ended — mark complete if last stage was completed
            if (!HasError)
            {
                IsComplete = true;
                await InvokeAsync(StateHasChanged);

                // Navigate back to ticket detail after brief delay
                await Task.Delay(TimeSpan.FromSeconds(2), cancellationToken);
                await InvokeAsync(() => Navigation.NavigateTo($"/tickets/{Number}"));
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on dispose/retry
        }
        catch (Exception ex)
        {
            HasError = true;
            ErrorMessage = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void UpdateStage(ResolutionEvent evt)
    {
        var summary = evt.Result.HasValue
            ? TruncateJson(evt.Result.Value)
            : evt.Error;

        Stages[evt.Stage] = new StageState(evt.Status, evt.Timestamp, summary);

        if (evt.Status.Equals("error", StringComparison.OrdinalIgnoreCase) ||
            evt.Status.Equals("failed", StringComparison.OrdinalIgnoreCase))
        {
            HasError = true;
            ErrorMessage = evt.Error ?? $"Stage '{evt.Stage}' failed.";
        }
    }

    private async Task RetryAsync()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        Stages.Clear();
        IsComplete = false;
        HasError = false;
        ErrorMessage = null;
        StateHasChanged();
        await StreamResolutionAsync(_cts.Token);
    }

    private static string FormatStageName(string stage) => stage switch
    {
        "classifier" => "Classifier",
        "incident_fetch" => "Incident Fetch",
        "request_fetch" => "Request Fetch",
        "incident_decomposer" => "Incident Decomposer",
        "request_decomposer" => "Request Decomposer",
        "evaluator" => "Evaluator",
        "resolution" => "Resolution",
        "escalation" => "Escalation",
        _ => stage.Replace("_", " ").ToUpperInvariant()
    };

    private static string GetIndicatorClass(StageState state) => state.Status.ToLowerInvariant() switch
    {
        "started" => "step-running",
        "completed" => "step-completed",
        "error" or "failed" => "step-failed",
        _ => "step-pending"
    };

    private static string? TruncateJson(JsonElement element)
    {
        var text = element.ToString();
        if (string.IsNullOrWhiteSpace(text))
        {
            return null;
        }

        return text.Length <= 180 ? text : $"{text[..180]}…";
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }

    private sealed record StageState(string Status, string? Timestamp, string? ResultSummary);
}

