@page "/tickets/{Number}/resolve"
@using System.Text.Json
@implements IDisposable
@inject ResolutionApiClient ResolutionApi

<PageTitle>Resolving @Number — TicketNow</PageTitle>

@if (!ResolutionApi.IsConfigured)
{
    <div class="alert-api-unconfigured">
        <div class="alert-icon">⚙️</div>
        <div>
            <strong>Resolution API not configured</strong>
            <p>Set <code>ResolutionApi:BaseUrl</code> in the app configuration to connect to the Python Resolution API.</p>
        </div>
    </div>
}
else
{
    <div class="run-progress-header">
        <div>
            <h1>Resolving Ticket @Number</h1>
            <p class="text-muted">@HeaderMessage</p>
        </div>
        @if (HasTerminalState && FinalOutcome == ResolutionOutcome.Resolved)
        {
            <span class="badge bg-success">Resolved</span>
        }
        else if (HasTerminalState && FinalOutcome == ResolutionOutcome.Escalated)
        {
            <span class="badge bg-warning text-dark">Escalated</span>
        }
        else if (HasTerminalState)
        {
            <span class="badge bg-warning text-dark">Finished</span>
        }
        else if (HasError)
        {
            <span class="badge bg-danger">Error</span>
        }
        else
        {
            <span class="badge bg-primary">Running</span>
        }
    </div>

    @if (!HasError && !HasTerminalState && Stages.Count == 0)
    {
        <div class="resolution-loading-card" role="status" aria-live="polite">
            <div class="spinner-border text-primary" aria-hidden="true"></div>
            <div>
                <strong>@(IsStarted ? "Opening resolution stream…" : "Preparing resolution…")</strong>
                <p class="mb-0 text-muted">This page is ready; progress events will appear as soon as the agent workflow responds.</p>
            </div>
        </div>
    }
    else
    {
        <div class="timeline">
            @foreach (var stage in Stages)
            {
                <div class="timeline-step">
                    <div class="step-indicator @GetIndicatorClass(stage.Value)"></div>
                    <div>
                        <div class="step-title">@FormatStageName(stage.Key)</div>
                        <div class="step-meta">
                            <span>@stage.Value.Status</span>
                            @if (stage.Value.Timestamp is not null)
                            {
                                <span>@stage.Value.Timestamp</span>
                            }
                        </div>
                        @if (stage.Value.ResultSummary is not null)
                        {
                            <div class="step-payload">@stage.Value.ResultSummary</div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (HasError)
    {
        <div class="alert @(HasTerminalState ? "alert-warning" : "alert-danger") mt-3">
            <strong>@(HasTerminalState ? "Resolution finished with errors:" : "Resolution failed:")</strong> @ErrorMessage
            <div class="mt-2">
                @if (!HasTerminalState)
                {
                    <button class="btn btn-outline-danger btn-sm" @onclick="RetryAsync">Retry</button>
                }
                <a class="btn btn-outline-secondary btn-sm ms-2" href="@($"/tickets/{Number}")">Back to Ticket</a>
            </div>
        </div>
    }
    else if (HasTerminalState)
    {
        <div class="final-card mt-3">
            <h4>@CompletionTitle</h4>
            <p>@CompletionMessage</p>
            @if (!string.IsNullOrWhiteSpace(FinalSummary))
            {
                <p class="text-muted small mb-3">@FinalSummary</p>
            }
            <a class="btn btn-primary" href="@DetailUrl">View Ticket Detail</a>
        </div>
    }
}

@code {
    [Parameter]
    public string Number { get; set; } = string.Empty;

    private Dictionary<string, StageState> Stages { get; } = new();
    private bool IsStarted;
    private bool HasTerminalState;
    private bool HasError;
    private string? ErrorMessage;
    private ResolutionOutcome? FinalOutcome;
    private string? FinalSummary;
    private CancellationTokenSource? _cts;

    protected override Task OnParametersSetAsync()
    {
        StartResolution();
        return Task.CompletedTask;
    }

    private void StartResolution()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        Stages.Clear();
        HasTerminalState = false;
        HasError = false;
        ErrorMessage = null;
        FinalOutcome = null;
        FinalSummary = null;
        IsStarted = false;

        _ = StreamResolutionAsync(_cts.Token);
    }

    private async Task StreamResolutionAsync(CancellationToken cancellationToken)
    {
        if (!ResolutionApi.IsConfigured)
        {
            return;
        }

        IsStarted = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await foreach (var evt in ResolutionApi.StreamResolutionAsync(Number, cancellationToken))
            {
                UpdateStage(evt);
                await InvokeAsync(StateHasChanged);
            }

            if (!HasTerminalState && !HasError)
            {
                HasError = true;
                ErrorMessage = "The resolution stream ended before the workflow reported a terminal status.";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on dispose/retry
        }
        catch (Exception ex)
        {
            HasError = true;
            ErrorMessage = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void UpdateStage(ResolutionEvent evt)
    {
        var summary = evt.Result.HasValue
            ? TruncateJson(evt.Result.Value)
            : evt.DisplayMessage;

        Stages[evt.DisplayStage] = new StageState(evt.EffectiveStatus, evt.Timestamp, summary);
        if (evt.IsTerminal)
        {
            HasTerminalState = true;
            FinalOutcome = GetFinalOutcome(evt);
            FinalSummary = summary ?? evt.DisplayMessage;
        }

        if (evt.IsFailure)
        {
            HasError = true;
            ErrorMessage = evt.DisplayMessage ?? $"Stage '{evt.DisplayStage}' failed.";
        }
    }

    private Task RetryAsync()
    {
        StartResolution();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static string FormatStageName(string stage) => stage switch
    {
        "classifier" => "Classifier",
        "incident_fetch" => "Incident Fetch",
        "request_fetch" => "Request Fetch",
        "incident_decomposer" => "Incident Decomposer",
        "request_decomposer" => "Request Decomposer",
        "evaluator" => "Evaluator",
        "resolution" => "Resolution",
        "escalation" => "Escalation",
        _ => stage.Replace("_", " ").ToUpperInvariant()
    };

    private string HeaderMessage => HasTerminalState
        ? CompletionMessage
        : "AI-powered resolution in progress";

    private string CompletionTitle => FinalOutcome switch
    {
        ResolutionOutcome.Resolved => "Ticket Resolved",
        ResolutionOutcome.Escalated => "Ticket Escalated",
        _ => "Resolution Finished"
    };

    private string CompletionMessage => FinalOutcome switch
    {
        ResolutionOutcome.Resolved => "The resolver completed and marked the ticket as resolved.",
        ResolutionOutcome.Escalated => "The resolver completed and escalated the ticket to a human specialist.",
        _ => "The resolver completed. Review the ticket detail for the latest state."
    };

    private string DetailUrl => $"/tickets/{Uri.EscapeDataString(Number)}?refresh={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";

    private static ResolutionOutcome GetFinalOutcome(ResolutionEvent evt)
    {
        if (evt.IsEscalated)
        {
            return ResolutionOutcome.Escalated;
        }

        return evt.IsResolved ? ResolutionOutcome.Resolved : ResolutionOutcome.Finished;
    }

    private static string GetIndicatorClass(StageState state) => state.Status.ToLowerInvariant() switch
    {
        "started" => "step-running",
        "escalated" => "step-escalated",
        "completed" or "complete" or "resolved" or "succeeded" or "success" or "done" => "step-completed",
        "error" or "failed" or "failure" => "step-failed",
        _ => "step-pending"
    };

    private static string? TruncateJson(JsonElement element)
    {
        var text = element.ToString();
        if (string.IsNullOrWhiteSpace(text))
        {
            return null;
        }

        return text.Length <= 180 ? text : $"{text[..180]}…";
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }

    private sealed record StageState(string Status, string? Timestamp, string? ResultSummary);

    private enum ResolutionOutcome
    {
        Resolved,
        Escalated,
        Finished
    }
}
